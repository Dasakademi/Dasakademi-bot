# ============================================
# .env.example — Kendi .env dosyanizi olusturun:
# cp .env.example .env && nano .env
# ============================================

# --- Veritabani ---
DATABASE_URL=postgresql://ajans:GUCLU_SIFRE_DEGISTIR@localhost/ajansdb

# --- Claude (Anthropic) API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Meta (Facebook/Instagram) Ads ---
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_long_lived_token
META_AD_ACCOUNT_ID=act_123456789

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=your_dev_token
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# --- Telegram (bildirim icin) ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Genel ---
SECRET_KEY=cok_guclu_rastgele_string_degistir
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Zamanlayici ---
MORNING_REPORT_HOUR=8
MORNING_REPORT_MINUTE=0
EVENING_REPORT_HOUR=18
EVENING_REPORT_MINUTE=0
